generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Prospect {
  id          String       @id @default(cuid())
  name        String
  company     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  transcripts Transcript[]
  summaries   Summary[]
}

model Transcript {
  id            String   @id @default(cuid())
  prospectId    String
  filename      String
  filePath      String
  extractedText String
  uploadedAt    DateTime @default(now())
  prospect      Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
}

model Summary {
  id           String   @id @default(cuid())
  prospectId   String
  keyTopics    Json
  actionItems  Json
  decisions    Json
  nextSteps    Json
  systemPrompt String?
  userPrompt   String?
  modelUsed    String?
  createdAt    DateTime @default(now())
  prospect     Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
}

model AppSettings {
  id       String @id @default(cuid())
  llmModel String @default("claude-haiku-4-5-20251001")
}
